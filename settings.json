{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(npm run dev*)",
      "Bash(npm run build*)",
      "Bash(npm run test*)",
      "Bash(npm run lint*)",
      "Bash(npm run check*)",
      "Bash(npm run start*)",
      "Bash(npx tsc *)",
      "Bash(npx expo start*)",
      "Bash(npx expo doctor*)",
      "Bash(npx expo config*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git stash list*)",
      "Bash(git stash show*)",
      "Bash(git stash push*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh pr status*)",
      "Bash(gh pr checks*)",
      "Bash(gh issue list*)",
      "Bash(gh issue view*)",
      "Bash(gh issue status*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(git show*)",
      "Bash(git rev-parse*)",
      "Bash(git worktree list*)",
      "Bash(git remote*)",
      "Bash(git tag*)",
      "Bash(git reflog*)",
      "Bash(git ls-files*)",
      "Bash(git blame*)",
      "Bash(git cherry*)",
      "Bash(git shortlog*)",
      "Bash(git config --get*)",
      "Bash(git config --list*)",
      "Bash(git merge-base*)",
      "Bash(git checkout -b *)",
      "Bash(git switch -c *)",
      "Bash(git switch *)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git stash pop*)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(git worktree add*)",
      "Bash(git worktree move*)",
      "Bash(git branch -m *)",
      "Bash(gh pr create*)",
      "Bash(gh pr merge*)",
      "Bash(gh issue create*)",
      "Bash(gh release create*)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(cat package.json*)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(node *)",
      "Bash(npx *)",
      "Bash(npm install*)",
      "Bash(npm ci*)",
      "Bash(npm list*)",
      "Bash(npm view*)",
      "Bash(npm outdated*)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(bun *)",
      "Bash(deno *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(curl *)",
      "Bash(jq *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(supabase *)",
      "Bash(vercel *)",
      "Bash(eas *)",
      "Bash(expo *)",
      "Bash(docker *)",
      "Bash(open *)",
      "Bash(killall *)",
      "Bash(lsof *)",
      "Bash(cd *)"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-compact.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-init.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/worktree-setup.sh",
            "timeout": 120000
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/clear_attention.sh",
            "timeout": 3000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/prompt-validator.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/working.sh",
            "timeout": 3000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "(Edit|Write)",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/protect-files.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/warn-commit.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/warn-pr.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "(Edit|Write)",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/auto-format.sh",
            "timeout": 10000,
            "async": true
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/scan-secrets.sh",
            "timeout": 5000,
            "async": true
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/suggest-verify.sh",
            "timeout": 3000,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/check-open-pr.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "prompt_input_exit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-cleanup.sh",
            "timeout": 5000,
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/attention.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/done.sh",
            "timeout": 3000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); eval \"$(echo \"$input\" | jq -r '@sh \"dir=\\(.workspace.current_dir | sub(\"/Users/[^/]+\"; \"~\"))\", @sh \"model=\\(.model.display_name)\", @sh \"cwd=\\(.workspace.current_dir)\", @sh \"cost=\\(.cost.total_cost_usd // 0)\", @sh \"ctx=\\(.context_window.used_percentage // 0)\"')\"; branch=$(git -C \"$cwd\" branch --show-current 2>/dev/null || echo '-'); printf \"\\033[2m%s [%s] (%s) $%.2f ctx:%s%%\\033[0m\" \"$dir\" \"$model\" \"$branch\" \"$cost\" \"$ctx\""
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": true,
    "Notion@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "supabase@claude-plugins-official": true
  },
  "voiceEnabled": false
}
